# ── VPC Music API — Production Environment ────────
# Copy this file to .env.production and fill in real values.

# ── Database ──────────────────────────────────────
# Cluster: solar-agent (DigitalOcean Managed PostgreSQL, nyc1)
DB_HOST=solar-agent-do-user-34220814-0.e.db.ondigitalocean.com
DB_PORT=25060
DB_USER=prd-vpc-music
DB_PASSWORD=CHANGE_ME
DB_NAME=prd-vpc-music
DATABASE_URL=postgresql://prd-vpc-music:CHANGE_ME@solar-agent-do-user-34220814-0.e.db.ondigitalocean.com:25060/prd-vpc-music?sslmode=require

# ── API ───────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://app.vpcmusic.life
FRONTEND_URL=https://app.vpcmusic.life

# ── PDF Parsing ──────────────────────────────────
# PDF_CO_API_KEY=

# ── Mailgun (API) ────────────────────────────────
MAILGUN_DOMAIN=e.vpcmusic.life
MAILGUN_API_KEY=CHANGE_ME
MAILGUN_API_BASE_URL=https://api.mailgun.net
EMAIL_FROM=VPC Music <noreply@e.vpcmusic.life>

# ── OAuth2 — Google ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://app.vpcmusic.life/api/auth/google/callback
