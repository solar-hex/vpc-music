{
  "name": "@vpc-music/api",
  "version": "0.1.0",
  "description": "VPC Music API — Express + Drizzle + PostgreSQL",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js,json src/index.js",
    "start": "node src/index.js",
    "db:push": "drizzle-kit push",
    "db:push:local": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 DOTENV_CONFIG_PATH=.env.local drizzle-kit push",
    "db:push:prd": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 DOTENV_CONFIG_PATH=.env.production drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prd": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 DOTENV_CONFIG_PATH=.env.production drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:studio:prd": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 DOTENV_CONFIG_PATH=.env.production drizzle-kit studio",
    "db:seed": "node src/seed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vpc-music/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "vitest": "^3.0.0"
  }
}
